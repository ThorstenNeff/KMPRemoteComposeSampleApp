<?xml version="1.0" encoding="utf-8"?>
<!--
  REM-172 S5 — permit cleartext HTTP ONLY to the local REM-173 dev server hosts (Android emulator's
  10.0.2.2 = the host loopback, plus 127.0.0.1 / localhost). Everything else stays HTTPS-only (the
  Android default). This is dev/demo-scoped: the server is localhost-only (no public exposure).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
